<Window
    x:Class="ADO_Tools_WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ADO_Tools_WinUI"
    xmlns:pages="using:ADO_Tools_WinUI.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="ADO Tools">

    <Window.SystemBackdrop>
        <!--<MicaBackdrop />-->
      <DesktopAcrylicBackdrop/>
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Full-width drag region covering the entire title bar row -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Background="Transparent" />

        <!-- Centered app title in the title bar -->
        <TextBlock Text="ADO Tools"
                   Grid.Row="0"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   IsHitTestVisible="False"
                   Opacity="0.9"
                   Padding="0,0,0,10"/>

        <!-- TabView overlays the same row; tab strip sits in the title bar -->
        <TabView x:Name="MainTabView"
                 Grid.Row="0" Grid.RowSpan="2"
                 IsAddTabButtonVisible="False"
                 CanDragTabs="False"
                 CanReorderTabs="False"
                 TabWidthMode="SizeToContent"
                 VerticalAlignment="Stretch"
                 Padding="0">

            <!-- 24px spacer to align tabs with content padding -->
            <TabView.TabStripHeader>
                <Grid Width="24" Background="Transparent" />
            </TabView.TabStripHeader>

            <TabView.TabStripFooter>
                <Grid HorizontalAlignment="Stretch">
                    <Button x:Name="btnSettings"
                            HorizontalAlignment="Right"
                            Margin="0,0,140,0"
                            VerticalAlignment="Center"
                            ToolTipService.ToolTip="Settings"
                            Click="BtnSettings_Click">
                        <SymbolIcon Symbol="Setting" />
                    </Button>
                </Grid>
            </TabView.TabStripFooter>

          <TabViewItem IsClosable="False">
            <TabViewItem.HeaderTemplate>
              <DataTemplate>
                <StackPanel Orientation="Horizontal" Spacing="12" Padding="8,4" MinWidth="200">
                  <SymbolIcon Symbol="Library" />
                  <TextBlock Text="Work Items" FontSize="16" FontWeight="SemiBold" />
                </StackPanel>
              </DataTemplate>
            </TabViewItem.HeaderTemplate>
            <pages:WorkItemsPage />
          </TabViewItem>


          <TabViewItem IsClosable="False">
            <TabViewItem.HeaderTemplate>
              <DataTemplate>
                <StackPanel Orientation="Horizontal" Spacing="12" Padding="8,4" MinWidth="200">
                  <SymbolIcon Symbol="Download" />
                  <TextBlock Text="Software Downloads" FontSize="16" FontWeight="SemiBold" />
                </StackPanel>
              </DataTemplate>
            </TabViewItem.HeaderTemplate>
            <pages:SoftwareDownloadPage />
          </TabViewItem>

            

        </TabView>
    </Grid>
</Window>
