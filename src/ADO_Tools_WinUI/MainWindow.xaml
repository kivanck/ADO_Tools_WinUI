<Window
    x:Class="ADO_Tools_WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ADO_Tools_WinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="using:ADO_Tools_WinUI.Pages"
    Title="ADO Tools"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <!--<MicaBackdrop />-->
        <DesktopAcrylicBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Full-width drag region covering the entire title bar row  -->
        <Grid
            x:Name="AppTitleBar"
            Grid.Row="0"
            Background="Transparent" />

        <!--  TabView overlays the same row; tab strip sits in the title bar  -->
        <TabView
            x:Name="MainTabView"
            Grid.Row="0"
            Grid.RowSpan="2"
            Padding="0"
            VerticalAlignment="Stretch"
            CanDragTabs="False"
            CanReorderTabs="False"
            IsAddTabButtonVisible="False"
            TabWidthMode="SizeToContent">

            <!--  24px spacer to align tabs with content padding  -->
            <TabView.TabStripHeader>
                <Grid Width="24" Background="Transparent" />
            </TabView.TabStripHeader>

            <TabView.TabStripFooter>
                <Grid HorizontalAlignment="Right" Margin="0,0,138,0">
                    <Button
                        x:Name="HelpButton"
                        Width="32"
                        Height="32"
                        Padding="0"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Click="HelpButton_Click"
                        CornerRadius="16"
                        ToolTipService.ToolTip="Open User Guide">
                        <TextBlock
                            FontFamily="Segoe Fluent Icons"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="&#xE897;" />
                    </Button>
                </Grid>
            </TabView.TabStripFooter>

            <TabViewItem x:Name="workItemsTab" IsClosable="False">
                <TabViewItem.HeaderTemplate>
                    <DataTemplate>
                        <StackPanel
                            MinWidth="200"
                            Padding="8,4"
                            Orientation="Horizontal"
                            Spacing="12">
                            <SymbolIcon Foreground="#5B9BD5" Symbol="Library" />
                            <TextBlock
                                FontSize="16"
                                FontWeight="SemiBold"
                                Text="Work Items" />
                        </StackPanel>
                    </DataTemplate>
                </TabViewItem.HeaderTemplate>
                <pages:WorkItemsPage />
            </TabViewItem>

            <TabViewItem x:Name="downloadsTab" IsClosable="False">
                <TabViewItem.HeaderTemplate>
                    <DataTemplate>
                        <StackPanel
                            MinWidth="200"
                            Padding="8,4"
                            Orientation="Horizontal"
                            Spacing="12">
                            <SymbolIcon Foreground="#6BA368" Symbol="Download" />
                            <TextBlock
                                FontSize="16"
                                FontWeight="SemiBold"
                                Text="Software Downloads" />
                        </StackPanel>
                    </DataTemplate>
                </TabViewItem.HeaderTemplate>
                <pages:SoftwareDownloadPage />
            </TabViewItem>

            <TabViewItem x:Name="settingsTab" IsClosable="False">
                <TabViewItem.HeaderTemplate>
                    <DataTemplate>
                        <StackPanel
                            MinWidth="200"
                            Padding="8,4"
                            Opacity="0.65"
                            Orientation="Horizontal"
                            Spacing="12">
                            <SymbolIcon Symbol="Setting" />
                            <TextBlock
                                FontSize="16"
                                FontWeight="SemiBold"
                                Text="Settings" />
                        </StackPanel>
                    </DataTemplate>
                </TabViewItem.HeaderTemplate>
                <pages:SettingsPage x:Name="settingsPage" />
            </TabViewItem>

        </TabView>
    </Grid>
</Window>
