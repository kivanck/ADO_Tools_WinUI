<Page
    x:Class="ADO_Tools_WinUI.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,16,0">
        <StackPanel Spacing="8" MaxWidth="600" HorizontalAlignment="Left">

            <!-- Connection settings card -->
            <TextBlock Text="Azure DevOps Connection"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Margin="0,0,0,4" />

            <Grid ColumnSpacing="16" RowSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBox Grid.Row="0" Grid.Column="0"
                         x:Name="txtOrganization"
                         Header="Organisation"
                         PlaceholderText="e.g. myorg" />

                <TextBox Grid.Row="0" Grid.Column="1"
                         x:Name="txtProject"
                         Header="Default Project"
                         PlaceholderText="e.g. Civil" />

                <PasswordBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                             x:Name="txtPAT"
                             Header="Personal Access Token (PAT)"
                             PlaceholderText="Paste your PAT here" />

                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                            Orientation="Horizontal" Spacing="12">
                    <Button x:Name="btnValidate"
                            Content="Validate Connection"
                            Style="{StaticResource AccentButtonStyle}"
                            Click="BtnValidate_Click" />
                    <InfoBar x:Name="ValidationStatus"
                             IsOpen="False"
                             IsClosable="False"
                             Severity="Informational" />
                </StackPanel>
            </Grid>

            <MenuFlyoutSeparator Margin="0,16" />

            <!-- Paths settings card -->
            <TextBlock Text="Paths"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Margin="0,0,0,4" />

            <TextBox x:Name="txtRootFolder"
                     Header="Work Items Download Folder"
                     PlaceholderText="e.g. D:\ADO_Items" />

            <TextBox x:Name="txtDownloadFolder"
                     Header="Software Download Folder"
                     PlaceholderText="e.g. D:\Downloads\Builds" />

            <MenuFlyoutSeparator Margin="0,16" />

            <!-- Search Index settings card -->
            <TextBlock Text="Search Index"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Margin="0,0,0,4" />
            <TextBlock Text="Configure the semantic search index. Build Index fetches new/changed items incrementally. Force Rebuild deletes the cache and re-indexes everything."
                       TextWrapping="Wrap"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,0,0,8" />

            <TextBox x:Name="txtSearchAreaPath"
                     Header="Iteration Path"
                     PlaceholderText="e.g. Civil\OpenCivil Designer\Backlog" />

            <CalendarDatePicker x:Name="dpCutoffDate"
                                Header="Index Cutoff Date (items created after this date)"
                                PlaceholderText="Select cutoff date"
                                DateFormat="{}{year.full}-{month.integer(2)}-{day.integer(2)}"
                                HorizontalAlignment="Stretch" />

            <TextBlock x:Name="lblSettingsCacheStatus"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Margin="0,4,0,0" />

            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,8,0,0">
                <Button x:Name="btnSettingsBuildIndex"
                        Click="BtnSettingsBuildIndex_Click"
                        Style="{StaticResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="14" Glyph="&#xEBD3;" />
                        <TextBlock Text="Build Index" />
                    </StackPanel>
                </Button>
                <Button x:Name="btnSettingsForceRebuild"
                        Click="BtnSettingsForceRebuild_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="14" Glyph="&#xE72C;" />
                        <TextBlock Text="Force Rebuild" />
                    </StackPanel>
                </Button>
                <ProgressRing x:Name="indexProgressRing"
                              IsActive="False"
                              Width="24" Height="24"
                              VerticalAlignment="Center" />
            </StackPanel>

            <MenuFlyoutSeparator Margin="0,16" />

            <!-- Search Result Columns -->
            <TextBlock Text="Search Result Columns"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Margin="0,0,0,4" />
            <TextBlock Text="Comma-separated ADO field reference names shown when displaying search and find-similar results. Use names like System.Id, System.Title, System.AreaPath, Microsoft.VSTS.Common.Priority, etc."
                       TextWrapping="Wrap"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,0,0,8" />
            <TextBox x:Name="txtSearchResultColumns"
                     Header="Columns"
                     TextWrapping="Wrap"
                     AcceptsReturn="False"
                     PlaceholderText="System.Id, System.Title, System.State, System.AreaPath, ..." />

            <MenuFlyoutSeparator Margin="0,16" />

            <!-- About -->
            <TextBlock Text="About"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Margin="0,0,0,4" />
            <TextBlock Text="Tools for Azure DevOps"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock Text="kivanc.karakas@bentley.com"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                       FontSize="12" />

            </StackPanel>
    </ScrollViewer>
</Page>
