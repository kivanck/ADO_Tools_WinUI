<Page
    x:Class="ADO_Tools_WinUI.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24,20,24,20" VerticalScrollBarVisibility="Auto">
        <Grid
            VerticalAlignment="Top"
            ColumnSpacing="24"
            RowSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  ROW 0, LEFT: Search Index  -->
            <Border
                Grid.Row="0"
                Grid.Column="0"
                Padding="20,16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border
                            Width="28"
                            Height="28"
                            Background="#6B69D6"
                            CornerRadius="6">
                            <FontIcon
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="14"
                                Foreground="White"
                                Glyph="&#xE721;" />
                        </Border>
                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{StaticResource BodyStrongTextBlockStyle}"
                            Text="Search Index" />
                    </StackPanel>

                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="Configure the semantic search index. Update Index fetches new/changed items incrementally. Force Rebuild deletes the cache and re-indexes everything."
                        TextWrapping="Wrap" />

                    <TextBox
                        x:Name="txtSearchAreaPath"
                        Header="Iteration Path"
                        PlaceholderText="e.g. Civil\OpenCivil Designer\Backlog" />

                    <CalendarDatePicker
                        x:Name="dpCutoffDate"
                        HorizontalAlignment="Stretch"
                        DateFormat="{}{year.full}-{month.integer(2)}-{day.integer(2)}"
                        Header="Index Cutoff Date (items created after this date)"
                        PlaceholderText="Select cutoff date" />

                    <TextBlock
                        x:Name="lblSettingsCacheStatus"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}" />

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button
                            x:Name="btnSettingsBuildIndex"
                            Click="BtnSettingsBuildIndex_Click"
                            Style="{StaticResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="14" Glyph="&#xEBD3;" />
                                <TextBlock Text="Update Index" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="btnSettingsForceRebuild" Click="BtnSettingsForceRebuild_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="14" Glyph="&#xE72C;" />
                                <TextBlock Text="Force Rebuild" />
                            </StackPanel>
                        </Button>
                        <ProgressRing
                            x:Name="indexProgressRing"
                            Width="24"
                            Height="24"
                            VerticalAlignment="Center"
                            IsActive="False" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!--  ROW 0, RIGHT: Connection  -->
            <Border
                Grid.Row="0"
                Grid.Column="1"
                Padding="20,16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border
                            Width="28"
                            Height="28"
                            Background="{ThemeResource SystemAccentColorDark1}"
                            CornerRadius="6">
                            <FontIcon
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="14"
                                Foreground="White"
                                Glyph="&#xE774;" />
                        </Border>
                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{StaticResource BodyStrongTextBlockStyle}"
                            Text="Azure DevOps Connection" />
                    </StackPanel>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBox
                            x:Name="txtOrganization"
                            Grid.Column="0"
                            Header="Organisation"
                            PlaceholderText="e.g. myorg" />
                        <TextBox
                            x:Name="txtProject"
                            Grid.Column="1"
                            Header="Default Project"
                            PlaceholderText="e.g. Civil" />
                    </Grid>

                    <PasswordBox
                        x:Name="txtPAT"
                        Header="Personal Access Token (PAT)"
                        PlaceholderText="Paste your PAT here" />

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button
                            x:Name="btnValidate"
                            Click="BtnValidate_Click"
                            Content="Validate Connection"
                            Style="{StaticResource AccentButtonStyle}" />
                        <InfoBar
                            x:Name="ValidationStatus"
                            IsClosable="False"
                            IsOpen="False"
                            Severity="Informational" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!--  ROW 1: Paths + About stacked  -->
            <StackPanel
                Grid.Row="1"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Spacing="12">

                <!--  Paths Card  -->
                <Border
                    Padding="20,16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border
                                Width="28"
                                Height="28"
                                Background="#107C10"
                                CornerRadius="6">
                                <FontIcon
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    Foreground="White"
                                    Glyph="&#xED25;" />
                            </Border>
                            <TextBlock
                                VerticalAlignment="Center"
                                Style="{StaticResource BodyStrongTextBlockStyle}"
                                Text="Download Paths" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Work Items Download Folder" Style="{StaticResource CaptionTextBlockStyle}" />
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox
                                    x:Name="txtRootFolder"
                                    Grid.Column="0"
                                    PlaceholderText="e.g. D:\ADO_Items" />
                                <Button
                                    Grid.Column="1"
                                    VerticalAlignment="Bottom"
                                    Click="BtnBrowseRootFolder_Click"
                                    ToolTipService.ToolTip="Browse…">
                                    <FontIcon FontSize="14" Glyph="&#xED25;" />
                                </Button>
                            </Grid>
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock Text="Software Download Folder" Style="{StaticResource CaptionTextBlockStyle}" />
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox
                                    x:Name="txtDownloadFolder"
                                    Grid.Column="0"
                                    PlaceholderText="e.g. D:\Downloads\Builds" />
                                <Button
                                    Grid.Column="1"
                                    VerticalAlignment="Bottom"
                                    Click="BtnBrowseDownloadFolder_Click"
                                    ToolTipService.ToolTip="Browse…">
                                    <FontIcon FontSize="14" Glyph="&#xED25;" />
                                </Button>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!--  About Card  -->
                <Border
                    Padding="20,16"
                    Background="#0DFFFFFF"
                    BorderBrush="{ThemeResource SystemAccentColorDark1}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border
                                Width="28"
                                Height="28"
                                Background="{ThemeResource SystemAccentColorDark1}"
                                CornerRadius="6">
                                <FontIcon
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    Foreground="White"
                                    Glyph="&#xE946;" />
                            </Border>
                            <TextBlock
                                VerticalAlignment="Center"
                                Style="{StaticResource BodyStrongTextBlockStyle}"
                                Text="About" />
                        </StackPanel>
                        <TextBlock x:Name="lblAboutTitle" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Text="kivanc.karakas@bentley.com" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
