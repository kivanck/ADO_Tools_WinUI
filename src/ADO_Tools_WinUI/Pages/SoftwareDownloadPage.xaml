<Page
    x:Class="ADO_Tools_WinUI.Pages.SoftwareDownloadPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ADO_Tools_WinUI.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24,20,24,20" ColumnSpacing="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.4*" MinWidth="380" />
            <ColumnDefinition Width="*" MinWidth="300" />
        </Grid.ColumnDefinitions>

        <!--  ═══════ LEFT COLUMN ═══════  -->
        <Grid Grid.Column="0" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  ── Product Selection Card ──  -->
            <Border
                Grid.Row="0"
                Padding="20,16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border
                            Width="28"
                            Height="28"
                            Background="{ThemeResource SystemAccentColorDark1}"
                            CornerRadius="6">
                            <FontIcon
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="14"
                                Foreground="White"
                                Glyph="&#xE71D;" />
                        </Border>
                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{StaticResource BodyStrongTextBlockStyle}"
                            Text="Product Selection" />
                    </StackPanel>

                    <!--  Product + Def ID + Project — single row  -->
                    <Grid ColumnSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox
                            x:Name="cmbProductName"
                            Grid.Column="0"
                            HorizontalAlignment="Stretch"
                            Header="Product"
                            SelectionChanged="CmbProductName_SelectionChanged" />
                        <TextBox
                            x:Name="txtDefinitionId"
                            Grid.Column="1"
                            Header="Def. ID"
                            PlaceholderText="6098" />
                        <TextBox
                            x:Name="txtProject"
                            Grid.Column="2"
                            Header="Project"
                            PlaceholderText="civil" />
                        <Button
                            x:Name="btnAddDefinition"
                            Grid.Column="3"
                            Width="35"
                            Height="32"
                            VerticalAlignment="Bottom"
                            Click="BtnAddDefinition_Click"
                            ToolTipService.ToolTip="Add definition">
                            <FontIcon FontSize="14" Glyph="&#xE710;" />
                        </Button>
                        <Button
                            x:Name="btnRemoveDefinition"
                            Grid.Column="4"
                            Width="35"
                            Height="32"
                            VerticalAlignment="Bottom"
                            Click="BtnRemoveDefinition_Click"
                            ToolTipService.ToolTip="Remove definition">
                            <FontIcon FontSize="14" Glyph="&#xE738;" />
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <!--  ── Build List Card (fills remaining height) ──  -->
            <Border
                Grid.Row="1"
                MinHeight="160"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid RowSpacing="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  Build card header  -->
                    <Border
                        Grid.Row="0"
                        Padding="20,14,20,10"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="0,0,0,1">
                        <Grid>
                            <StackPanel
                                VerticalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="10">
                                <Border
                                    Width="28"
                                    Height="28"
                                    Background="#0078D4"
                                    CornerRadius="6">
                                    <FontIcon
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        Foreground="White"
                                        Glyph="&#xE9F5;" />
                                </Border>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Style="{StaticResource BodyStrongTextBlockStyle}"
                                    Text="Build Selection" />
                            </StackPanel>
                            <Button
                                x:Name="btnShowBentleySoftware"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Click="BtnShowBentleySoftware_Click"
                                ToolTipService.ToolTip="Show installed Bentley products">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon FontSize="14" Glyph="&#xE71D;" />
                                    <TextBlock FontSize="12" Text="Installed Software" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <!--  Load row: count + load + filter  -->
                    <Grid
                        Grid.Row="1"
                        Padding="16,10,16,8"
                        ColumnSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <NumberBox
                            x:Name="numBuildCount"
                            Grid.Column="0"
                            Width="100"
                            Maximum="200"
                            Minimum="1"
                            SpinButtonPlacementMode="Compact"
                            Value="30" />
                        <Button
                            x:Name="btnLoadBuilds"
                            Grid.Column="1"
                            Height="32"
                            Click="BtnLoadBuilds_Click"
                            Content="Load Builds"
                            Style="{StaticResource AccentButtonStyle}" />
                        <AutoSuggestBox
                            x:Name="buildFilterBox"
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            PlaceholderText="Filter builds…"
                            QueryIcon="Find"
                            TextChanged="BuildFilterBox_TextChanged" />
                    </Grid>

                    <!--  Column headers  -->
                    <Grid
                        Grid.Row="2"
                        Padding="16,8,16,6"
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="0,1,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="1.5*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            Style="{StaticResource BodyStrongTextBlockStyle}"
                            Text="Product" />
                        <TextBlock
                            Grid.Column="1"
                            Style="{StaticResource BodyStrongTextBlockStyle}"
                            Text="Version" />
                        <TextBlock
                            Grid.Column="2"
                            Style="{StaticResource BodyStrongTextBlockStyle}"
                            Text="Result" />
                        <TextBlock
                            Grid.Column="3"
                            Style="{StaticResource BodyStrongTextBlockStyle}"
                            Text="Finish Time" />
                    </Grid>

                    <!--  Build list (grows with window)  -->
                    <ListView
                        x:Name="lvBuilds"
                        Grid.Row="3"
                        Padding="0,0,0,4"
                        SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:BuildInfoViewModel">
                                <Grid Padding="4,6" ColumnSpacing="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="1.2*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="1.5*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource BodyTextBlockStyle}"
                                        Text="{x:Bind ProductName}"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Foreground="{x:Bind VersionBrush}"
                                        Style="{StaticResource BodyTextBlockStyle}"
                                        Text="{x:Bind DisplayVersion}"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        Grid.Column="2"
                                        VerticalAlignment="Center"
                                        Foreground="{x:Bind ResultBrush}"
                                        Style="{StaticResource BodyTextBlockStyle}"
                                        Text="{x:Bind Result}"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        Grid.Column="3"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource BodyTextBlockStyle}"
                                        Text="{x:Bind FinishTime}"
                                        TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

        <!--  ═══════ RIGHT COLUMN ═══════  -->
        <Grid Grid.Column="1" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  ── Install Options Card ──  -->
            <Border
                Grid.Row="0"
                Padding="20,16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="14">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border
                            Width="28"
                            Height="28"
                            Background="#107C10"
                            CornerRadius="6">
                            <FontIcon
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="14"
                                Foreground="White"
                                Glyph="&#xED25;" />
                        </Border>
                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{StaticResource BodyStrongTextBlockStyle}"
                            Text="Install Options" />
                    </StackPanel>

                    <!--  Options toggles  -->
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ToggleSwitch
                            x:Name="toggleDownloadOnly"
                            Grid.Column="0"
                            MinWidth="0"
                            Header="Download Only"
                            OffContent=""
                            OnContent="" />
                        <ToggleSwitch
                            x:Name="toggleCleanUninstall"
                            Grid.Column="1"
                            MinWidth="0"
                            Header="Clean Uninstall"
                            OffContent=""
                            OnContent="" />
                    </Grid>
                </StackPanel>
            </Border>

            <!--  ── Action Bar with download progress ──  -->
            <StackPanel Grid.Row="1" Spacing="6">
                <!--  Download progress indicator (hidden when idle)  -->
                <Border
                    x:Name="downloadStatusPanel"
                    Padding="14,10"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    CornerRadius="6"
                    Visibility="Collapsed">
                    <Grid RowSpacing="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                x:Name="txtDownloadStatus"
                                Grid.Column="0"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="Downloading…"
                                TextTrimming="CharacterEllipsis" />
                            <TextBlock
                                x:Name="txtDownloadSpeed"
                                Grid.Column="1"
                                Foreground="DodgerBlue"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="" />
                        </Grid>
                        <ProgressBar
                            x:Name="downloadProgressBar"
                            Grid.Row="1"
                            Maximum="100"
                            Minimum="0"
                            Value="0" />
                    </Grid>
                </Border>


                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button
                        x:Name="btnUpdate"
                        Grid.Column="0"
                        Height="44"
                        HorizontalAlignment="Stretch"
                        Click="BtnUpdate_Click"
                        Style="{StaticResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon FontSize="16" Glyph="&#xE896;" />
                            <TextBlock FontWeight="SemiBold" Text="Run Update" />
                        </StackPanel>
                    </Button>
                    <Button
                        x:Name="btnStopDownload"
                        Grid.Column="1"
                        Height="44"
                        Click="BtnStopDownload_Click"
                        ToolTipService.ToolTip="Cancel the current download"
                        Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon
                                FontSize="16"
                                Foreground="#E81123"
                                Glyph="&#xE002;" />
                            <TextBlock FontWeight="SemiBold" Text="Stop" />
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>

            <!--  ── Activity Log Card (modern ListView) ──  -->
            <Border
                Grid.Row="2"
                MinHeight="120"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!--  Log header  -->
                    <Border
                        Grid.Row="0"
                        Padding="16,12,16,10"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="0,0,0,1">
                        <Grid>
                            <StackPanel
                                VerticalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="10">
                                <Border
                                    Width="28"
                                    Height="28"
                                    Background="#6B69D6"
                                    CornerRadius="6">
                                    <FontIcon
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        Foreground="White"
                                        Glyph="&#xE756;" />
                                </Border>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Style="{StaticResource BodyStrongTextBlockStyle}"
                                    Text="Activity Log" />
                                <TextBlock
                                    x:Name="txtLogCount"
                                    VerticalAlignment="Center"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Text="" />
                            </StackPanel>
                            <Button
                                x:Name="btnClearLog"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Click="BtnClearLog_Click"
                                ToolTipService.ToolTip="Clear log">
                                <FontIcon FontSize="14" Glyph="&#xE74D;" />
                            </Button>
                        </Grid>
                    </Border>

                    <!--  Log entries list  -->
                    <ListView
                        x:Name="lvLog"
                        Grid.Row="1"
                        Padding="4,4,4,4"
                        ItemContainerTransitions="{x:Null}"
                        SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:LogEntryViewModel">
                                <Grid Padding="8,5" ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon
                                        Grid.Column="0"
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        Foreground="{x:Bind GlyphBrush, Mode=OneWay}"
                                        Glyph="{x:Bind Glyph, Mode=OneWay}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Text="{x:Bind Message, Mode=OneWay}"
                                        TextWrapping="Wrap" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!--  Installer status banner  -->
                    <InfoBar
                        x:Name="installerInfoBar"
                        Grid.Row="2"
                        IsClosable="False"
                        IsOpen="False"
                        Severity="Informational">
                        <InfoBar.Content>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock
                                    x:Name="txtInstallerLabel"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Text="Windows Installer is running…" />
                                <TextBlock
                                    x:Name="txtInstallerElapsed"
                                    VerticalAlignment="Center"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Text="Elapsed: 0s" />
                            </StackPanel>
                        </InfoBar.Content>
                    </InfoBar>

                    <ProgressBar
                        x:Name="progressBar"
                        Grid.Row="3"
                        IsIndeterminate="False"
                        Visibility="Collapsed" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
