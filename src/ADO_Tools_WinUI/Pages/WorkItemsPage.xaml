<Page
    x:Class="ADO_Tools_WinUI.Pages.WorkItemsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24,20,24,20" RowSpacing="1">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  ROW 0 — Connection  -->
        <Border
            Grid.Row="0"
            Padding="20,16"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <StackPanel Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Border
                        Width="28"
                        Height="28"
                        Background="{ThemeResource SystemAccentColorDark1}"
                        CornerRadius="6">
                        <FontIcon
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="14"
                            Foreground="White"
                            Glyph="&#xE774;" />
                    </Border>
                    <TextBlock
                        VerticalAlignment="Center"
                        Style="{StaticResource BodyStrongTextBlockStyle}"
                        Text="Connection" />
                </StackPanel>
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="Project" />
                    <TextBox
                        x:Name="txtProjectName"
                        Grid.Column="1"
                        Width="160"
                        PlaceholderText="e.g. Civil" />
                    <Button
                        x:Name="btnConnect"
                        Grid.Column="2"
                        Height="32"
                        VerticalAlignment="Bottom"
                        Click="BtnConnect_Click"
                        Style="{StaticResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="14" Glyph="&#xE774;" />
                            <TextBlock Text="Connect" />
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

        <!--  ROW 1 — Pivot: Query / Search tabs  -->
        <Border
            Grid.Row="1"
            Padding="4,0,4,8"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <Pivot x:Name="pivotMode">

                <!--  ═══ Query Tab ═══  -->
                <PivotItem>
                    <PivotItem.Header>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="14" Glyph="&#xE8A7;" />
                            <TextBlock Text="Query" />
                        </StackPanel>
                    </PivotItem.Header>

                    <StackPanel Margin="0,10,0,0" Spacing="12">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox
                                x:Name="cmbQueries"
                                Grid.Column="0"
                                HorizontalAlignment="Stretch"
                                PlaceholderText="Connect to project first…" />
                            <Button
                                x:Name="btnReadItems"
                                Grid.Column="1"
                                Height="32"
                                VerticalAlignment="Bottom"
                                Click="BtnReadItems_Click"
                                IsEnabled="False"
                                Style="{StaticResource AccentButtonStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon FontSize="14" Glyph="&#xE9F5;" />
                                    <TextBlock Text="Read Items" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!--  Search within query results  -->
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <AutoSuggestBox
                                x:Name="txtQuerySearch"
                                Grid.Column="0"
                                IsEnabled="False"
                                PlaceholderText="Search within query results (rich text)…"
                                QueryIcon="Find"
                                QuerySubmitted="TxtQuerySearch_QuerySubmitted" />
                            <Button
                                x:Name="btnClearQuerySearch"
                                Grid.Column="1"
                                Height="32"
                                Click="BtnClearQuerySearch_Click"
                                ToolTipService.ToolTip="Clear search and show all query results">
                                <FontIcon FontSize="14" Glyph="&#xE894;" />
                            </Button>
                        </Grid>
                    </StackPanel>
                </PivotItem>

                <!--  ═══ Search Tab ═══  -->
                <PivotItem>
                    <PivotItem.Header>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="14" Glyph="&#xE721;" />
                            <TextBlock Text="Search" />
                        </StackPanel>
                    </PivotItem.Header>

                    <StackPanel Margin="0,10,0,0" Spacing="10">
                        <!--  Search box & options  -->
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox
                                x:Name="cmbSearchMode"
                                Grid.Column="0"
                                Width="180"
                                VerticalAlignment="Center"
                                SelectedIndex="0"
                                SelectionChanged="CmbSearchMode_SelectionChanged"
                                ToolTipService.ToolTip="Hybrid combines semantic + keyword via rank fusion; Semantic uses AI embeddings; Keyword uses BM25 word matching">
                                <ComboBoxItem Content="Hybrid (RRF)" />
                                <ComboBoxItem Content="Semantic" />
                                <ComboBoxItem Content="Keyword (BM25)" />
                            </ComboBox>
                            <AutoSuggestBox
                                x:Name="txtSemanticSearch"
                                Grid.Column="1"
                                IsEnabled="False"
                                PlaceholderText="Search by meaning — e.g. 'crash when opening large files'…"
                                QueryIcon="Find"
                                QuerySubmitted="TxtSemanticSearch_QuerySubmitted" />
                            <CheckBox
                                x:Name="chkExcludeDone"
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                Content="Exclude Done"
                                IsChecked="True" />
                            <StackPanel
                                Grid.Column="3"
                                VerticalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="6">
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Text="Top" />
                                <NumberBox
                                    x:Name="numTopResults"
                                    Width="100"
                                    Maximum="500"
                                    Minimum="1"
                                    SpinButtonPlacementMode="Compact"
                                    Value="30" />
                            </StackPanel>
                            <Button
                                x:Name="btnClearSearch"
                                Grid.Column="4"
                                Height="32"
                                Click="BtnClearSearch_Click"
                                ToolTipService.ToolTip="Clear search and show query results">
                                <FontIcon FontSize="14" Glyph="&#xE894;" />
                            </Button>
                            <Button
                                x:Name="btnUpdateIndex"
                                Grid.Column="5"
                                Height="32"
                                Click="BtnUpdateIndex_Click"
                                ToolTipService.ToolTip="Fetch new/changed items and update the search cache">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon FontSize="14" Glyph="&#xE895;" />
                                    <TextBlock Text="Update" />
                                </StackPanel>
                            </Button>
                        </Grid>
                        <TextBlock
                            x:Name="lblCacheStatus"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{StaticResource CaptionTextBlockStyle}" />
                    </StackPanel>
                </PivotItem>
            </Pivot>
        </Border>

        <!--  ROW 2 — Actions Toolbar (two cards side by side)  -->
        <Grid Grid.Row="2" ColumnSpacing="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  Left card: Grid selection actions  -->
            <Border
                Grid.Column="0"
                Padding="16,8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button
                        x:Name="btnDownloadSelected"
                        Height="32"
                        VerticalAlignment="Center"
                        Click="BtnDownloadSelected_Click"
                        IsEnabled="False"
                        ToolTipService.ToolTip="Download attachments for selected items in the grid">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="14" Glyph="&#xE896;" />
                            <TextBlock x:Name="lblDownloadSelectedText" Text="Download Selected" />
                        </StackPanel>
                    </Button>

                    <StackPanel
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="6">
                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="Highlight" />
                        <NumberBox
                            x:Name="numHighlightDays"
                            Width="90"
                            Maximum="365"
                            Minimum="0"
                            SpinButtonPlacementMode="Compact"
                            ValueChanged="NumHighlightDays_ValueChanged"
                            Value="5" />
                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="days" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!--  Right card: Single item actions (by ID)  -->
            <Border
                Grid.Column="1"
                Padding="16,8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                    <TextBlock
                        VerticalAlignment="Center"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="Work Item" />
                    <NumberBox
                        x:Name="txtFindSimilarId"
                        Width="120"
                        PlaceholderText="e.g. 2011414"
                        SpinButtonPlacementMode="Hidden"
                        ToolTipService.ToolTip="Enter a work item ID or select one from the grid" />

                    <Button
                        x:Name="btnFindSimilar"
                        Height="32"
                        VerticalAlignment="Center"
                        Click="BtnFindSimilar_Click"
                        IsEnabled="False"
                        ToolTipService.ToolTip="Find similar work items across the backlog using semantic + keyword search">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="14" Glyph="&#xE721;" />
                            <TextBlock Text="Find Similar" />
                        </StackPanel>
                    </Button>

                    <Button
                        x:Name="btnDownloadSingle"
                        Height="32"
                        VerticalAlignment="Center"
                        Click="BtnDownloadSingle_Click"
                        IsEnabled="False"
                        ToolTipService.ToolTip="Download attachments for this work item">
                        <FontIcon FontSize="14" Glyph="&#xE896;" />
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <!--  ROW 3 — Work Items Data Grid  -->
        <Border
            Grid.Row="3"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <Grid RowSpacing="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!--  List Header with Context Badge  -->
                <Border
                    Grid.Row="0"
                    Padding="20,14,20,10"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!--  Icon + title  -->
                        <Border
                            x:Name="badgeIcon"
                            Grid.Column="0"
                            Width="28"
                            Height="28"
                            VerticalAlignment="Center"
                            Background="#0078D4"
                            CornerRadius="6">
                            <FontIcon
                                x:Name="badgeGlyph"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="14"
                                Foreground="White"
                                Glyph="&#xE8A7;" />
                        </Border>
                        <TextBlock
                            x:Name="lblContextBadge"
                            Grid.Column="1"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            Style="{StaticResource BodyStrongTextBlockStyle}"
                            Text="Work Items" />

                        <TextBlock
                            x:Name="lblItemCount"
                            Grid.Column="3"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </Grid>
                </Border>

                <!--  Dataa Grid for work items  -->
                <controls:DataGrid
                    x:Name="dataGridWorkItems"
                    Grid.Row="1"
                    Padding="4"
                    AlternatingRowBackground="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    AutoGenerateColumns="False"
                    CanUserReorderColumns="True"
                    CanUserResizeColumns="True"
                    CanUserSortColumns="True"
                    DoubleTapped="DataGridWorkItems_DoubleTapped"
                    GridLinesVisibility="Horizontal"
                    IsReadOnly="True"
                    SelectionMode="Extended"
                    SelectionChanged="DataGridWorkItems_SelectionChanged"
                    Sorting="DataGridWorkItems_Sorting" />
            </Grid>
        </Border>

        <!--  ROW 4 — Status Bar  -->
        <Border
            Grid.Row="4"
            Padding="20,10"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    x:Name="lblDownloading"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                <TextBlock
                    x:Name="lblSize"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <ProgressBar
                    x:Name="progressBar"
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    IsIndeterminate="False"
                    Visibility="Collapsed" />
            </Grid>
        </Border>
    </Grid>
</Page>
