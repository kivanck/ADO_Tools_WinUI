<Page
    x:Class="ADO_Tools_WinUI.Pages.WorkItemsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24,20,24,20" RowSpacing="1">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ROW 0 — Connection & Folder -->
        <Border Grid.Row="0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8" Padding="20">
            <Grid ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Connection -->
                <StackPanel Grid.Column="0" Spacing="14">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border Background="{ThemeResource SystemAccentColorDark1}"
                                CornerRadius="6" Width="28" Height="28">
                            <FontIcon Glyph="&#xE774;" FontSize="14" Foreground="White"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="Connection"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Project"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   VerticalAlignment="Center" />
                        <TextBox x:Name="txtProjectName"
                                 Grid.Column="1"
                                 PlaceholderText="e.g. Civil"
                                 Width="160" />
                        <Button x:Name="btnConnect"
                                Grid.Column="2"
                                VerticalAlignment="Bottom" Height="32"
                                Style="{StaticResource AccentButtonStyle}"
                                Click="BtnConnect_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE774;" FontSize="14" />
                                <TextBlock Text="Connect" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>

                <!-- Download Folder -->
                <StackPanel Grid.Column="1" Spacing="14">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border Background="#107C10"
                                CornerRadius="6" Width="28" Height="28">
                            <FontIcon Glyph="&#xED25;" FontSize="14" Foreground="White"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="Download Folder"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtRootFolder"
                                 Grid.Column="0"
                                 PlaceholderText="e.g. D:\ADO_Items" />
                        <Button x:Name="btnBrowseFolder"
                                Grid.Column="1"
                                VerticalAlignment="Bottom" Height="32"
                                ToolTipService.ToolTip="Browse for folder"
                                Click="BtnBrowseFolder_Click">
                            <FontIcon Glyph="&#xED25;" FontSize="14" />
                        </Button>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ROW 1 — Query & Actions -->
        <Border Grid.Row="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8" Padding="20">
            <StackPanel Spacing="14">

                <!-- Query Selection -->
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Border Background="#0078D4"
                            CornerRadius="6" Width="28" Height="28">
                        <FontIcon Glyph="&#xE8A7;" FontSize="14" Foreground="White"
                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Query &amp; Actions"
                               Style="{StaticResource BodyStrongTextBlockStyle}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="cmbQueries"
                              Grid.Column="0"
                              HorizontalAlignment="Stretch"
                              PlaceholderText="Connect to project first…" />
                    <Button x:Name="btnReadItems"
                            Grid.Column="1"
                            VerticalAlignment="Bottom" Height="32"
                            IsEnabled="False"
                            Style="{StaticResource AccentButtonStyle}"
                            Click="BtnReadItems_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE9F5;" FontSize="14" />
                            <TextBlock Text="Read Items" />
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Action buttons -->
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />  <!-- 0: Download Selected -->
                        <ColumnDefinition Width="Auto" />  <!-- 1: Compare -->
                        <ColumnDefinition Width="Auto" />  <!-- 2: Highlight days -->
                        <ColumnDefinition Width="*" />     <!-- 3: Spacer -->
                        <ColumnDefinition Width="Auto" />  <!-- 4: Item ID -->
                        <ColumnDefinition Width="Auto" />  <!-- 5: Download Single -->
                    </Grid.ColumnDefinitions>

                    <Button x:Name="btnDownloadSelected"
                            Grid.Column="0"
                            IsEnabled="False" Height="32"
                            VerticalAlignment="Bottom"
                            Click="BtnDownloadSelected_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE896;" FontSize="14" />
                            <TextBlock Text="Download Selected" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnCompare"
                            Grid.Column="1"
                            IsEnabled="False" Height="32"
                            VerticalAlignment="Bottom"
                            ToolTipService.ToolTip="Find similar work items"
                            Click="BtnCompare_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE721;" FontSize="14" />
                            <TextBlock Text="Compare" />
                        </StackPanel>
                    </Button>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8"
                                VerticalAlignment="Bottom">
                        <Border Background="#CA5010"
                                CornerRadius="4" Width="22" Height="22"
                                VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE7E6;" FontSize="11" Foreground="White"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="Highlight days"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   VerticalAlignment="Center" />
                        <NumberBox x:Name="numHighlightDays"
                                   Value="5" Minimum="0" Maximum="365"
                                   SpinButtonPlacementMode="Compact"
                                   Width="100"
                                   ValueChanged="NumHighlightDays_ValueChanged" />
                    </StackPanel>

                    <!-- Single item download -->
                    <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="8"
                                VerticalAlignment="Bottom">
                        <TextBlock Text="Item ID"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   VerticalAlignment="Center" />
                        <NumberBox x:Name="txtSingleItemId"
                                   PlaceholderText="e.g. 102654"
                                   Width="120"
                                   SpinButtonPlacementMode="Hidden" />
                    </StackPanel>
                    <Button x:Name="btnDownloadSingle"
                            Grid.Column="5"
                            IsEnabled="False" Height="32"
                            VerticalAlignment="Bottom"
                            Click="BtnDownloadSingle_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE896;" FontSize="14" />
                            <TextBlock Text="Download Single" />
                        </StackPanel>
                    </Button>

                </Grid>
            </StackPanel>
        </Border>

        <!-- ROW 2 — Work Items List -->
        <Border Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8">
            <Grid RowSpacing="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- List Header -->
                <Border Grid.Row="0" Padding="20,14,20,10"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="0,0,0,1">
                  <Grid>
                    <Grid.ColumnDefinitions>                      
                      <ColumnDefinition Width="Auto" /><!-- 2: Highlight days -->
                      <ColumnDefinition Width="*" /><!-- 3: Spacer -->
                      <ColumnDefinition Width="Auto" /><!-- 4: Item ID -->
                     </Grid.ColumnDefinitions>
                    <!-- 4: Item ID -->
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" Grid.Column="0">
                        <Border Background="#6B69D6"
                                CornerRadius="6" Width="28" Height="28">
                            <FontIcon Glyph="&#xE8FD;" FontSize="14" Foreground="White"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="Work Items"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   VerticalAlignment="Center" />
                      </StackPanel>
                      <TextBlock x:Name="lblItemCount"
                                Grid.Column="3"
                                VerticalAlignment="Bottom"
                                Margin="0,0,0,6"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                  </Grid>
                </Border>

                <ListView Grid.Row="1"
                          x:Name="listWorkItems"
                          SelectionMode="Extended"
                          IsItemClickEnabled="True"
                          Padding="4"
                          ItemClick="ListWorkItems_ItemClick"
                          DoubleTapped="ListWorkItems_DoubleTapped">
                    <ListView.HeaderTemplate>
                        <DataTemplate>
                            <Grid Padding="12,8" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="130" />
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="180" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="ID" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="1" Text="Title" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="2" Text="State" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="3" Text="Created By" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="4" Text="Date" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="5" Text="Type" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="6" Text="Iteration" FontWeight="SemiBold" />
                            </Grid>
                        </DataTemplate>
                    </ListView.HeaderTemplate>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="12,6" ColumnSpacing="8" Background="{Binding RowBackground}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="130" />
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="180" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Id}" />
                                <TextBlock Grid.Column="1" Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="2" Text="{Binding State}" />
                                <TextBlock Grid.Column="3" Text="{Binding CreatedBy}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="4" Text="{Binding CreatedDateShort}" />
                                <TextBlock Grid.Column="5" Text="{Binding TypeName}" />
                                <TextBlock Grid.Column="6" Text="{Binding IterationShort}" TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <!-- ROW 3 — Status Bar -->
        <Border Grid.Row="3"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8" Padding="20,10">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="lblDownloading"
                           Grid.Column="0"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                           VerticalAlignment="Center" />
                <TextBlock x:Name="lblSize"
                           Grid.Column="1"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center" />
                <ProgressBar x:Name="progressBar"
                             Grid.Column="2"
                             IsIndeterminate="False"
                             Visibility="Collapsed"
                             VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</Page>
