<Page
    x:Class="ADO_Tools_WinUI.Pages.WorkItemsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24,16,24,24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ROW 0 Ś Connection & Folder Card -->
        <Border Grid.Row="0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8" Padding="16">
            <Grid ColumnSpacing="12" RowSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox x:Name="txtProjectName"
                         Grid.Column="0"
                         Header="Project"
                         PlaceholderText="e.g. Civil"
                         Width="160" />

                <Button x:Name="btnConnect"
                        Grid.Column="1"
                        VerticalAlignment="Bottom"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="BtnConnect_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Globe" />
                        <TextBlock Text="Connect" />
                    </StackPanel>
                </Button>

                <TextBox x:Name="txtRootFolder"
                         Grid.Column="3"
                         Header="Download Root Folder"
                         PlaceholderText="e.g. D:\ADO_Items" />

                <Button x:Name="btnBrowseFolder"
                        Grid.Column="4"
                        VerticalAlignment="Bottom"
                        Content="Browseģ"
                        Click="BtnBrowseFolder_Click" />
            </Grid>
        </Border>

        <!-- ROW 1 Ś Query & Actions Card -->
        <Border Grid.Row="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8" Padding="16">
            <Grid RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Query row -->
                <Grid Grid.Row="0" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ComboBox x:Name="cmbQueries"
                              Grid.Column="0"
                              Header="Queries"
                              HorizontalAlignment="Stretch"
                              PlaceholderText="Connect to project firstģ" />

                    <Button x:Name="btnReadItems"
                            Grid.Column="1"
                            VerticalAlignment="Bottom"
                            IsEnabled="False"
                            Click="BtnReadItems_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <SymbolIcon Symbol="Refresh" />
                            <TextBlock Text="Read Items" />
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Action buttons row -->
                <Grid Grid.Row="1" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button x:Name="btnDownloadSelected"
                            Grid.Column="0"
                            IsEnabled="False"
                            Click="BtnDownloadSelected_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <SymbolIcon Symbol="Download" />
                            <TextBlock Text="Download Selected" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnCompare"
                            Grid.Column="1"
                            IsEnabled="False"
                            ToolTipService.ToolTip="Find similar work items"
                            Click="BtnCompare_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <SymbolIcon Symbol="Find" />
                            <TextBlock Text="Compare" />
                        </StackPanel>
                    </Button>

                    <TextBlock Grid.Column="2"
                               Text="Highlight"
                               VerticalAlignment="Center" />
                    <NumberBox x:Name="numHighlightDays"
                               Grid.Column="3"
                               Value="5" Minimum="0" Maximum="365"
                               SpinButtonPlacementMode="Compact"
                               Width="100"
                               Header="days"
                               ValueChanged="NumHighlightDays_ValueChanged" />

                    <!-- Single item download -->
                    <NumberBox x:Name="txtSingleItemId"
                               Grid.Column="5"
                               PlaceholderText="Item ID"
                               Width="120"
                               SpinButtonPlacementMode="Hidden" />
                    <Button x:Name="btnDownloadSingle"
                            Grid.Column="6"
                            IsEnabled="False"
                            Click="BtnDownloadSingle_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <SymbolIcon Symbol="Download" />
                            <TextBlock Text="Download Single" />
                        </StackPanel>
                    </Button>

                    <TextBlock x:Name="lblItemCount"
                               Grid.Column="7"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </Grid>
            </Grid>
        </Border>

        <!-- ROW 2 Ś Work Items List -->
        <Border Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8" Padding="4">
            <ListView x:Name="listWorkItems"
                      SelectionMode="Extended"
                      IsItemClickEnabled="True"
                      ItemClick="ListWorkItems_ItemClick"
                      DoubleTapped="ListWorkItems_DoubleTapped">
                <ListView.HeaderTemplate>
                    <DataTemplate>
                        <Grid Padding="12,8" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="180" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="ID" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="Title" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="2" Text="State" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="3" Text="Created By" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="4" Text="Date" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="5" Text="Type" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="6" Text="Iteration" FontWeight="SemiBold" />
                        </Grid>
                    </DataTemplate>
                </ListView.HeaderTemplate>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="12,6" ColumnSpacing="8" Background="{Binding RowBackground}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="180" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Id}" />
                            <TextBlock Grid.Column="1" Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="2" Text="{Binding State}" />
                            <TextBlock Grid.Column="3" Text="{Binding CreatedBy}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="4" Text="{Binding CreatedDateShort}" />
                            <TextBlock Grid.Column="5" Text="{Binding TypeName}" />
                            <TextBlock Grid.Column="6" Text="{Binding IterationShort}" TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>

        <!-- ROW 3 Ś Status Bar -->
        <Border Grid.Row="3"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8" Padding="12,8">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="lblDownloading"
                           Grid.Column="0"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                <TextBlock x:Name="lblSize"
                           Grid.Column="1"
                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                <ProgressBar x:Name="progressBar"
                             Grid.Column="2"
                             IsIndeterminate="False"
                             Visibility="Collapsed"
                             VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</Page>
