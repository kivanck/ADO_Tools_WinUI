<Page
x:Class="ADO_Tools_WinUI.Pages.WorkItemsPage"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
mc:Ignorable="d">

<Grid Padding="24,20,24,20" RowSpacing="1">
    <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- ROW 0 — Connection & Folder -->
    <Border Grid.Row="0"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1" CornerRadius="8" Padding="20">
        <Grid ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Connection -->
            <StackPanel Grid.Column="0" Spacing="14">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Border Background="{ThemeResource SystemAccentColorDark1}"
                            CornerRadius="6" Width="28" Height="28">
                        <FontIcon Glyph="&#xE774;" FontSize="14" Foreground="White"
                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Connection"
                               Style="{StaticResource BodyStrongTextBlockStyle}"
                               VerticalAlignment="Center" />
                </StackPanel>
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Project"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               VerticalAlignment="Center" />
                    <TextBox x:Name="txtProjectName"
                             Grid.Column="1"
                             PlaceholderText="e.g. Civil"
                             Width="160" />
                    <Button x:Name="btnConnect"
                            Grid.Column="2"
                            VerticalAlignment="Bottom" Height="32"
                            Style="{StaticResource AccentButtonStyle}"
                            Click="BtnConnect_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE774;" FontSize="14" />
                            <TextBlock Text="Connect" />
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>

            <!-- Download Folder -->
            <StackPanel Grid.Column="1" Spacing="14">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Border Background="#107C10"
                            CornerRadius="6" Width="28" Height="28">
                        <FontIcon Glyph="&#xED25;" FontSize="14" Foreground="White"
                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Download Folder"
                               Style="{StaticResource BodyStrongTextBlockStyle}"
                               VerticalAlignment="Center" />
                </StackPanel>
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="txtRootFolder"
                             Grid.Column="0"
                             PlaceholderText="e.g. D:\ADO_Items" />
                    <Button x:Name="btnBrowseFolder"
                            Grid.Column="1"
                            VerticalAlignment="Bottom" Height="32"
                            ToolTipService.ToolTip="Browse for folder"
                            Click="BtnBrowseFolder_Click">
                        <FontIcon Glyph="&#xED25;" FontSize="14" />
                    </Button>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>

    <!-- ROW 1 — Pivot: Query / Search tabs -->
    <Border Grid.Row="1"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1" CornerRadius="8" Padding="4,0,4,8">
        <Pivot x:Name="pivotMode">

            <!-- ═══ Query Tab ═══ -->
            <PivotItem>
                <PivotItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8A7;" FontSize="14" />
                        <TextBlock Text="Query" />
                    </StackPanel>
                </PivotItem.Header>

                <StackPanel Spacing="12" Margin="0,10,0,0">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="cmbQueries"
                                  Grid.Column="0"
                                  HorizontalAlignment="Stretch"
                                  PlaceholderText="Connect to project first…" />
                        <Button x:Name="btnReadItems"
                                Grid.Column="1"
                                VerticalAlignment="Bottom" Height="32"
                                IsEnabled="False"
                                Style="{StaticResource AccentButtonStyle}"
                                Click="BtnReadItems_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE9F5;" FontSize="14" />
                                <TextBlock Text="Read Items" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </PivotItem>

            <!-- ═══ Search Tab ═══ -->
            <PivotItem>
                <PivotItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE721;" FontSize="14" />
                        <TextBlock Text="Search" />
                    </StackPanel>
                </PivotItem.Header>

                <StackPanel Spacing="10" Margin="0,10,0,0">
                    <!-- Index controls -->
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Iteration Path"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   VerticalAlignment="Center" />
                        <TextBox x:Name="txtAreaPath" Grid.Column="1"
                                 PlaceholderText="e.g. Civil\OpenCivil Designer\Backlog" />
                        <Button x:Name="btnBuildIndex"
                                Grid.Column="2" Height="32"
                                IsEnabled="False"
                                ToolTipService.ToolTip="Build or update the local embedding cache for the specified area path"
                                Click="BtnBuildIndex_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xEBD3;" FontSize="14" />
                                <TextBlock Text="Build Index" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="btnForceRebuild"
                                Grid.Column="3" Height="32"
                                IsEnabled="False"
                                ToolTipService.ToolTip="Delete existing cache and re-embed all work items from scratch"
                                Click="BtnForceRebuild_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE72C;" FontSize="14" />
                                <TextBlock Text="Force Rebuild" />
                            </StackPanel>
                        </Button>
                        <TextBlock x:Name="lblCacheStatus"
                                   Grid.Column="4"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <!-- Search box & options -->
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="cmbSearchMode"
                                  Grid.Column="0"
                                  SelectedIndex="0" Width="180"
                                  VerticalAlignment="Center"
                                  ToolTipService.ToolTip="Semantic uses AI embeddings; Keyword uses BM25 word matching"
                                  SelectionChanged="CmbSearchMode_SelectionChanged">
                            <ComboBoxItem Content="Semantic" />
                            <ComboBoxItem Content="Keyword (BM25)" />
                        </ComboBox>
                        <AutoSuggestBox x:Name="txtSemanticSearch"
                                        Grid.Column="1"
                                        PlaceholderText="Search by meaning — e.g. 'crash when opening large files'…"
                                        QueryIcon="Find"
                                        IsEnabled="False"
                                        QuerySubmitted="TxtSemanticSearch_QuerySubmitted" />
                        <CheckBox x:Name="chkExcludeDone"
                                  Grid.Column="2"
                                  Content="Exclude Done"
                                  IsChecked="True"
                                  VerticalAlignment="Center" />
                        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6"
                                    VerticalAlignment="Center">
                            <TextBlock Text="Top"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       VerticalAlignment="Center" />
                            <NumberBox x:Name="numTopResults"
                                       Value="30" Minimum="1" Maximum="500"
                                       SpinButtonPlacementMode="Compact"
                                       Width="100" />
                        </StackPanel>
                        <Button x:Name="btnClearSearch"
                                Grid.Column="4" Height="32"
                                ToolTipService.ToolTip="Clear search and show query results"
                                Click="BtnClearSearch_Click">
                            <FontIcon Glyph="&#xE894;" FontSize="14" />
                        </Button>
                    </Grid>
                </StackPanel>
            </PivotItem>
        </Pivot>
    </Border>

    <!-- ROW 2 — Shared Actions Toolbar -->
    <Border Grid.Row="2"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1" CornerRadius="8" Padding="16,8">
        <Grid ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button x:Name="btnDownloadSelected"
                    Grid.Column="0"
                    IsEnabled="False" Height="32"
                    VerticalAlignment="Center"
                    Click="BtnDownloadSelected_Click">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE896;" FontSize="14" />
                    <TextBlock Text="Download Selected" />
                </StackPanel>
            </Button>

            <Button x:Name="btnCompare"
                    Grid.Column="1"
                    IsEnabled="False" Height="32"
                    VerticalAlignment="Center"
                    ToolTipService.ToolTip="Find similar work items"
                    Click="BtnCompare_Click">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE721;" FontSize="14" />
                    <TextBlock Text="Compare" />
                </StackPanel>
            </Button>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8"
                        VerticalAlignment="Center">
                <Border Background="#CA5010"
                        CornerRadius="4" Width="22" Height="22"
                        VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE7E6;" FontSize="11" Foreground="White"
                              HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="Highlight days"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center" />
                <NumberBox x:Name="numHighlightDays"
                           Value="5" Minimum="0" Maximum="365"
                           SpinButtonPlacementMode="Compact"
                           Width="100"
                           ValueChanged="NumHighlightDays_ValueChanged" />
            </StackPanel>

            <!-- Single item download -->
            <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="8"
                        VerticalAlignment="Center">
                <TextBlock Text="Item ID"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center" />
                <NumberBox x:Name="txtSingleItemId"
                           PlaceholderText="e.g. 102654"
                           Width="120"
                           SpinButtonPlacementMode="Hidden" />
            </StackPanel>
            <Button x:Name="btnDownloadSingle"
                    Grid.Column="5"
                    IsEnabled="False" Height="32"
                    VerticalAlignment="Center"
                    Click="BtnDownloadSingle_Click">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE896;" FontSize="14" />
                    <TextBlock Text="Download Single" />
                </StackPanel>
            </Button>
        </Grid>
    </Border>

    <!-- ROW 3 — Work Items List -->
    <Border Grid.Row="3"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1" CornerRadius="8">
        <Grid RowSpacing="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- List Header with Context Badge -->
            <Border Grid.Row="0" Padding="20,14,20,10"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Icon + title -->
                    <Border x:Name="badgeIcon" Grid.Column="0"
                            Background="#0078D4"
                            CornerRadius="6" Width="28" Height="28"
                            VerticalAlignment="Center">
                        <FontIcon x:Name="badgeGlyph" Glyph="&#xE8A7;" FontSize="14"
                                  Foreground="White"
                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock x:Name="lblContextBadge" Grid.Column="1"
                               Text="Work Items"
                               Style="{StaticResource BodyStrongTextBlockStyle}"
                               VerticalAlignment="Center" Margin="10,0,0,0" />

                    <TextBlock x:Name="lblItemCount" Grid.Column="3"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </Grid>
            </Border>

                <ListView Grid.Row="1"
                          x:Name="listWorkItems"
                          SelectionMode="Extended"
                          IsItemClickEnabled="True"
                          Padding="4"
                          ItemClick="ListWorkItems_ItemClick"
                          DoubleTapped="ListWorkItems_DoubleTapped">
                    <ListView.HeaderTemplate>
                        <DataTemplate>
                            <Grid Padding="12,8" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="130" />
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="ID" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="1" Text="Title" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="2" Text="State" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="3" Text="Created By" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="4" Text="Date" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="5" Text="Type" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="6" Text="Iteration" FontWeight="SemiBold" />
                            </Grid>
                        </DataTemplate>
                    </ListView.HeaderTemplate>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="12,6" ColumnSpacing="8" Background="{Binding RowBackground}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="130" />
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Id}" />
                                <TextBlock Grid.Column="1" Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="2" Text="{Binding State}" />
                                <TextBlock Grid.Column="3" Text="{Binding CreatedBy}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="4" Text="{Binding CreatedDateShort}" />
                                <TextBlock Grid.Column="5" Text="{Binding TypeName}" />
                                <TextBlock Grid.Column="6" Text="{Binding IterationShort}" TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <!-- ROW 4 — Status Bar -->
        <Border Grid.Row="4"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8" Padding="20,10">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="lblDownloading"
                           Grid.Column="0"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                           VerticalAlignment="Center" />
                <TextBlock x:Name="lblSize"
                           Grid.Column="1"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center" />
                <ProgressBar x:Name="progressBar"
                             Grid.Column="2"
                             IsIndeterminate="False"
                             Visibility="Collapsed"
                             VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</Page>
